NODE_ENV=
PORT=

DATABASE_URL=
# If credentials/cookies are enabled, CORS_ORIGIN must be explicit (not "*").
CORS_ORIGIN=

# Database
POSTGRES_PASSWORD=
POSTGRES_USER=
POSTGRES_DB=

# Auth / Tokens
JWT_SECRET=
JWT_ACCESS_EXPIRES_IN=
REFRESH_TOKEN_EXPIRES_IN=

# Auth cookies
# Оставьте пустым, чтобы не указывать атрибут домена cookie (только для одного хоста).
AUTH_COOKIE_DOMAIN=
# true/false;  если не задано, в качестве резервного варианта используется NODE_ENV (production => true).
AUTH_COOKIE_SECURE=
ACCESS_COOKIE_NAME=access_token
REFRESH_COOKIE_NAME=refresh_token
# Необязательный секретный ключ для подписанных куки в промежуточном ПО cookie-parser.
COOKIE_SECRET=

# Redis
REDIS_PASSWORD=password
REDIS_USER=default
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URI='redis://${REDIS_USER}:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}'
# redis://default:root@localhost:port