NODE_ENV=development
PORT=3001

DATABASE_URL=postgresql://postgres:postgres@postgres:5432/exact_hunter
# If credentials/cookies are enabled, CORS_ORIGIN must be explicit (not "*").
CORS_ORIGIN=http://localhost:5000,http://localhost:5001

# Database
POSTGRES_PASSWORD=admin
POSTGRES_USER=postgres
POSTGRES_DB=exact_hunter

# Auth / Tokens
JWT_SECRET=change-me-to-a-strong-random-secret
JWT_ACCESS_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# Auth cookies
# Оставьте пустым, чтобы не указывать атрибут домена cookie (только для одного хоста).
AUTH_COOKIE_DOMAIN=
# true/false;  если не задано, в качестве резервного варианта используется NODE_ENV (production => true).
AUTH_COOKIE_SECURE=
CANDIDATE_ACCESS_COOKIE_NAME=candidate_access_token
CANDIDATE_REFRESH_COOKIE_NAME=candidate_refresh_token
EMPLOYER_ACCESS_COOKIE_NAME=employer_access_token
EMPLOYER_REFRESH_COOKIE_NAME=employer_refresh_token
# Необязательный секретный ключ для подписанных куки в промежуточном ПО cookie-parser.
COOKIE_SECRET=
